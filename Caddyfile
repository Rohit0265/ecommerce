# Caddyfile
:{$PORT} {
    # Order Service (stripping the /orders prefix)
    route /orders/* {
        uri strip_prefix /orders
        reverse_proxy localhost:8001
    }

    # Payment Service (stripping the /payments prefix)
    route /payments/* {
        uri strip_prefix /payments
        reverse_proxy localhost:8002
    }

    # Auth Service (stripping the /auth prefix)
    route /auth/* {
        uri strip_prefix /auth
        reverse_proxy localhost:8003
    }

    # Fallback: Forward all other requests to Product Service
    reverse_proxy * localhost:8000
}
