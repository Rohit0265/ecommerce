# Caddyfile
{
    admin off
}

:{$PORT} {
    # Order Service (auto-strips the /orders prefix)
    handle_path /orders/* {
        reverse_proxy localhost:8001
    }

    # Payment Service (auto-strips the /payments prefix)
    handle_path /payments/* {
        reverse_proxy localhost:8002
    }

    # Auth Service (auto-strips the /auth prefix)
    handle_path /auth/* {
        reverse_proxy localhost:8003
    }

    # Fallback: Forward all other requests to Product Service
    handle {
        reverse_proxy localhost:8000
    }
}
