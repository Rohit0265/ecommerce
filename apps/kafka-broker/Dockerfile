FROM apache/kafka:4.1.1

# Sensible KRaft defaults for Railway
ENV KAFKA_NODE_ID=1
ENV KAFKA_PROCESS_ROLES=broker,controller
ENV KAFKA_LISTENERS=INTERNAL://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093
ENV KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka.railway.internal:9092
ENV KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
ENV KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
ENV KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
ENV KAFKA_CONTROLLER_QUORUM_VOTERS=1@localhost:9093
ENV KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
ENV KAFKA_LOG_DIRS=/var/lib/kafka/data

# Quiet down the Kafka broker logging to prevent Railway log rate limits (500 logs/sec)
ENV KAFKA_LOG4J_ROOT_LOGLEVEL=WARN
ENV KAFKA_LOG4J_LOGGERS="kafka.controller=WARN,kafka.coordinator=WARN,org.apache.kafka=WARN"

# Expose the internal client port and controller port
EXPOSE 9092 9093
